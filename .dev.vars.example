# Worker secrets / vars — copy to `worker/.dev.vars` for local dev (gitignored).
# In prod these are `wrangler secret put`. NEVER commit real values or put them in the SPA bundle.

# --- Model (Track B + planning) ---
OPENROUTER_KEY=            # OpenRouter API key (Worker secret)
AI_GATEWAY_URL=            # Cloudflare AI Gateway OpenRouter URL
CF_ACCOUNT_ID=            # Cloudflare account id (for AI Gateway)
CF_GATEWAY_ID=            # AI Gateway id

# --- Observability (optional; console default when unset) ---
ARIZE_API_KEY=            # enables the Arize/OpenInference emitter; unset = console via `wrangler tail`
ARIZE_SPACE_ID=

# --- Track B: incorporate (optional; the how-to pack works keyless with verified static links) ---
COMPANIES_HOUSE_KEY=      # only needed for the live name-availability check; demo uses the verified pack

# --- CORS / origins ---
ALLOWED_ORIGINS=http://localhost:5173,https://ldnmxx-hack.pages.dev,https://qte77.github.io

# KV bindings (OPPORTUNITIES, etc.) live in worker/wrangler.toml, not here.
