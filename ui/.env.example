# ui/.env — LOCAL DEV ONLY (gitignored). Vite inlines every VITE_* var into the client bundle, so NEVER
# put a secret in a VITE_* var — it would ship in the deployed build. There is deliberately no key env
# var: supply a model key at runtime via the ⚙ Key panel (held in memory, forwarded to the Worker and
# resolved server-side). Copy this file to ui/.env.

# Dev override for the Worker /api base. Empty = same-origin: the SPA calls /api/* and Vite proxies it
# to the local `wrangler dev` worker on :8787. Set to a URL to target a remote worker instead.
VITE_WORKER_BASE=

# Dev override for the SPA base path (read by vite.config.ts; default "/", since CF Pages serves at the
# domain root). Rarely needed. Copy this file to ui/.env.
VITE_BASE=
