# ui/.env — LOCAL DEV ONLY (gitignored). Vite inlines VITE_* into the client bundle, so NEVER put a
# real key here for a deployed build. In prod, supply a model key via the dashboard BYOK field
# (held in memory only). Copy to ui/.env to use.

# Dev override for the Worker /run base. Empty = same-origin: the SPA calls /run and Vite proxies it
# to the local `wrangler dev` worker on :8787. Set to a URL to target a remote worker instead.
VITE_WORKER_BASE=

# Optional dev prefill for the BYOK field (key + model).
VITE_BYOK_API_KEY=
VITE_BYOK_MODEL=
