# Cloudflare DEPLOY-time auth for `wrangler deploy` (non-interactive / CI). NOT worker runtime secrets
# (those live in worker/.dev.vars — see .dev.vars.example). You do NOT need this if you've run
# `wrangler login` (interactive OAuth). Copy to `worker/.env` (gitignored), fill in, then:
#
#   set -a; source worker/.env; set +a
#   npm run deploy      # (= wrangler deploy)

# API token with the "Edit Cloudflare Workers" template (https://dash.cloudflare.com/profile/api-tokens).
CLOUDFLARE_API_TOKEN=
# Account id (dash -> Workers & Pages -> Account ID), if your token can reach more than one account.
CLOUDFLARE_ACCOUNT_ID=
