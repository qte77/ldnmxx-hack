{
  "name": "groundwork-worker",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "deploy": "wrangler deploy --config wrangler.toml",
    "tail": "wrangler tail --format pretty",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run lint:shared",
    "lint:shared": "cd .. && worker/node_modules/.bin/eslint shared",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4"
  }
}
