# Worker RUNTIME secrets/vars — copy to `worker/.dev.vars` (this folder, gitignored) for local
# `wrangler dev`. In prod set each with `wrangler secret put <NAME>`. NEVER commit real values or put
# them in the SPA bundle. (Cloudflare DEPLOY-time auth lives in worker/.env.example, not here.)

# --- Model (Track B + planning) ---
OPENROUTER_KEY=           # OpenRouter API key (Worker secret)
AI_GATEWAY_URL=          # Cloudflare AI Gateway OpenRouter URL
CF_ACCOUNT_ID=           # Cloudflare account id (for AI Gateway)
CF_GATEWAY_ID=           # AI Gateway id

# --- Observability (OPTIONAL; console default when unset) ---
ARIZE_API_KEY=           # set to enable the Arize emitter; UNSET = console spans via `wrangler tail` (Phase-1 default)
ARIZE_SPACE_ID=

# --- Track B: incorporate (optional) ---
COMPANIES_HOUSE_KEY=     # only for the live name-availability check; demo uses the verified pack

# --- CORS / origins (also mirrored in wrangler.toml [vars]) ---
ALLOWED_ORIGINS=http://localhost:5173,https://qte77.github.io

# KV bindings (OPPORTUNITIES, etc.) live in worker/wrangler.toml, not here.
