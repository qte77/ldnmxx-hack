# deps / build
node_modules/
dist/
*.tsbuildinfo
.wrangler/
.venv/
__pycache__/
*.pyc

# secrets / local env — never commit; *.example templates stay tracked. .env files scatter across
# folders (ui/, worker/) — no leading slash, so these match at any depth.
.env
.env.*
!.env.example
!.env.*.example
.dev.vars
.dev.vars*
!.dev.vars.example
*.local

# ToU-gated scraped data (only data/demo/ is committed)
data/real/

# Claude Code local settings + its temp write files (rules/skills stay tracked)
.claude/settings.local.json*

# misc
*.log
.DS_Store
