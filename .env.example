# Full-CF deploy credentials. Copy to `.env` (gitignored) and fill in — scripts/provision_cf.sh +
# scripts/finish_cf.sh auto-source a repo-root `.env` if present (single source of truth for the deploy,
# which spans ui/ → Pages and worker/ → the Worker).
#
# API-token scopes (Custom token): Cloudflare Pages·Edit + Workers Scripts·Edit + Zone·Read + Zone·DNS·Edit
# (+ Workers AI·Read for the Worker's AI binding). Zone Resources = sortmy.london.
# Create at: https://dash.cloudflare.com/profile/api-tokens · Account ID: dashboard sidebar / `wrangler whoami`.
#
# NOTE: runtime Worker secrets (OPENROUTER_KEY, ARIZE_API_KEY, ARIZE_SPACE_ID) do NOT belong here —
# set them with `wrangler secret put <NAME>` (prod) or worker/.dev.vars (local dev).

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
